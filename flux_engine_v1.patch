+// --- NEURON BROWSER PATCH: ANSP CORE LOGIC ---
+void NavigationPredictor::RunAutonomousPrediction(
+    const std::vector<blink::mojom::AnchorElementMetricsPtr>& metrics) {
+  std::vector<GURL> new_predictions;
+  for (const auto& metric : metrics) {
+    GURL target_url = metric->target_url;
+    if (!target_url.is_valid() || !target_url.SchemeIsHTTPOrHTTPS()) {
+      continue;
+    }
+
+    double confidence_score = 0.3; // Baseline
+
+    // 1. Structural Saliency (using URL instead of text due to privacy in modern IPC)
+    std::string path(target_url.path());
+    if (path.find("next") != std::string::npos || 
+        path.find("checkout") != std::string::npos ||
+        path.find("submit") != std::string::npos) {
+      confidence_score += 0.5;
+    }
+
+    // 2. Viewport Analysis
+    if (metric->ratio_distance_root_top < 1.0f) {
+      confidence_score += 0.2;
+    }
+
+    // Trigger Speculative Prerender if confidence is high enough
+    if (confidence_score >= 0.4) {
+      new_predictions.push_back(target_url);
+    }
+  }
+
+  if (!new_predictions.empty() && MaySendTraffic()) {
+    NavigationPredictorKeyedService* service =
+        NavigationPredictorKeyedServiceFactory::GetForProfile(
+            Profile::FromBrowserContext(
+                render_frame_host().GetBrowserContext()));
+    if (service) {
+      content::WebContents* web_contents =
+          content::WebContents::FromRenderFrameHost(&render_frame_host());
+      service->OnPredictionUpdated(
+          web_contents, render_frame_host().GetLastCommittedURL().GetWithoutRef(),
+          NavigationPredictorKeyedService::PredictionSource::
+              kAnchorElementsParsedFromWebPage,
+          new_predictions);
+    }
+  }
+}
